{%- liquid
  assign align = block.settings.alignment
  assign justify = 'center'
  if align == 'left'
    assign justify = 'flex-start'
  elsif align == 'right'
    assign justify = 'flex-end'
  endif
  assign accent = block.settings.accent_color
-%}
<div class="modify-trust-badges" style="box-sizing:border-box; width:100%; margin:1rem 0 0; padding-top:1rem; border-top:1px solid #ececec; font-family:inherit;" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <p class="modify-trust-heading" style="font-size:.72rem; text-transform:uppercase; letter-spacing:.06em; opacity:.55; margin:0 0 .65rem; text-align:{{ justify | replace: 'flex-start','left' | replace: 'flex-end','right' }};">{{ block.settings.heading }}</p>
  {%- endif -%}

  <div class="modify-trust-row" style="display:flex; flex-wrap:wrap; align-items:center; justify-content:{{ justify }}; gap:.6rem 1.6rem; row-gap:.6rem;">
    {%- if block.settings.show_secure -%}
      <span class="modify-trust-item" style="display:inline-flex; align-items:center; gap:.45rem; font-size:.82rem; line-height:1.2; white-space:nowrap; color:inherit;">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true" style="color:{{ accent }}; flex-shrink:0;"><path fill="currentColor" d="M12 1 3 5v6c0 5 3.8 9.7 9 11 5.2-1.3 9-6 9-11V5l-9-4Zm-1 15-4-4 1.4-1.4L11 13.2l5.6-5.6L18 9l-7 7Z"/></svg>
        <span>{{ block.settings.secure_text }}</span>
      </span>
    {%- endif -%}

    {%- if block.settings.show_guarantee -%}
      <span class="modify-trust-item" style="display:inline-flex; align-items:center; gap:.45rem; font-size:.82rem; line-height:1.2; white-space:nowrap; color:inherit;">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true" style="color:{{ accent }}; flex-shrink:0;"><path fill="currentColor" d="M12 1 3 5v6c0 5 3.8 9.7 9 11 5.2-1.3 9-6 9-11V5l-9-4Zm0 6a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm0 11c-1.7 0-3.2-.8-4-2 .1-1.3 2.7-2 4-2s3.9.7 4 2c-.8 1.2-2.3 2-4 2Z"/></svg>
        <span>{{ block.settings.guarantee_text }}</span>
      </span>
    {%- endif -%}

    {%- if block.settings.show_returns -%}
      <span class="modify-trust-item" style="display:inline-flex; align-items:center; gap:.45rem; font-size:.82rem; line-height:1.2; white-space:nowrap; color:inherit;">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true" style="color:{{ accent }}; flex-shrink:0;"><path fill="currentColor" d="M12 5V1L7 6l5 5V7a6 6 0 1 1-6 6H4a8 8 0 1 0 8-8Z"/></svg>
        <span>{{ block.settings.returns_text }}</span>
      </span>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Modify Trust Badges",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre (optionnel)", "default": "Achat 100% sécurisé" },
    { "type": "color", "id": "accent_color", "label": "Couleur des icônes", "default": "#16a34a" },
    {
      "type": "select", "id": "alignment", "label": "Alignement", "default": "center",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ]
    },
    { "type": "header", "content": "Badges" },
    { "type": "checkbox", "id": "show_secure", "label": "Paiement sécurisé", "default": true },
    { "type": "text", "id": "secure_text", "label": "Texte paiement", "default": "Paiement sécurisé" },
    { "type": "checkbox", "id": "show_guarantee", "label": "Garantie", "default": true },
    { "type": "text", "id": "guarantee_text", "label": "Texte garantie", "default": "Satisfait ou remboursé 30j" },
    { "type": "checkbox", "id": "show_returns", "label": "Retours", "default": true },
    { "type": "text", "id": "returns_text", "label": "Texte retours", "default": "Retours gratuits" }
  ]
}
{% endschema %}
