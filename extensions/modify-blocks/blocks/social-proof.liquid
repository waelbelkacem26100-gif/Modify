{%- liquid
  assign rating = block.settings.rating | times: 1.0
  assign full = rating | floor
-%}
<div class="modify-social-proof" style="margin: 1rem 0;" {{ block.shopify_attributes }}>
  <div class="modify-stars" role="img" aria-label="{{ rating }} / 5" style="display: inline-flex; align-items: center; gap: 2px;">
    {%- for i in (1..5) -%}
      {%- if i <= full -%}
        {%- assign star_color = block.settings.star_color -%}
      {%- else -%}
        {%- assign star_color = '#d1d5db' -%}
      {%- endif -%}
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" style="color: {{ star_color }};">
        <path fill="currentColor" d="m12 2 3 6.3 6.9.9-5 4.8 1.2 6.8L12 18l-6.1 3.6 1.2-6.8-5-4.8 6.9-.9L12 2Z"/>
      </svg>
    {%- endfor -%}
    <span class="modify-rating-num" style="margin-left: .4rem; font-weight: 600; font-size: .9rem;">{{ rating }}</span>
  </div>

  <p class="modify-review-count" style="font-size: .8rem; opacity: .7; margin: .25rem 0 0;">
    {{ block.settings.count }} {{ block.settings.count_label }}
  </p>

  {%- if block.settings.quote != blank -%}
    <blockquote class="modify-review-quote" style="font-style: italic; font-size: .9rem; margin: .6rem 0 0; padding-left: .8rem; border-left: 3px solid {{ block.settings.star_color }};">
      “{{ block.settings.quote }}”
      {%- if block.settings.author != blank -%}
        <cite style="display: block; font-style: normal; font-size: .8rem; opacity: .6; margin-top: .25rem;">— {{ block.settings.author }}</cite>
      {%- endif -%}
    </blockquote>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Modify Social Proof",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "range", "id": "rating", "label": "Note moyenne", "min": 1, "max": 5, "step": 0.1, "default": 4.8 },
    { "type": "color", "id": "star_color", "label": "Couleur des étoiles", "default": "#f59e0b" },
    { "type": "text", "id": "count", "label": "Nombre d'avis", "default": "247" },
    { "type": "text", "id": "count_label", "label": "Libellé", "default": "avis clients vérifiés" },
    { "type": "header", "content": "Témoignage (optionnel)" },
    { "type": "textarea", "id": "quote", "label": "Citation", "default": "Qualité au rendez-vous, livraison rapide. Je recommande !" },
    { "type": "text", "id": "author", "label": "Auteur", "default": "Marie L., cliente vérifiée" }
  ]
}
{% endschema %}
