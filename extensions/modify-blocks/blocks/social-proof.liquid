{%- liquid
  # Real review data only — sourced from the store's review metafields
  # (Shopify Product Reviews / Judge.me / Loox all write reviews.rating + reviews.rating_count).
  # NEVER fabricate reviews: if there are none, show an honest message instead.
  assign rating_obj = product.metafields.reviews.rating.value
  assign rating = 0
  assign scale = 5
  if rating_obj != blank
    assign rating = rating_obj.rating | times: 1.0
    assign scale = rating_obj.scale_max | default: 5
  endif
  assign count = product.metafields.reviews.rating_count.value | default: 0 | times: 1
  if rating > 0 and scale != 5 and scale != 0
    assign rating = rating | times: 5.0 | divided_by: scale
  endif
  assign rating_rounded = rating | round: 1
  assign full = rating | round
  assign star_color = block.settings.star_color
-%}
<div class="modify-social-proof" style="box-sizing:border-box; width:100%; margin:1rem 0; font-family:inherit;" {{ block.shopify_attributes }}>
  {%- if count > 0 and rating > 0 -%}
    <div class="modify-sp-row" style="display:flex; align-items:center; flex-wrap:wrap; gap:.5rem;">
      <span class="modify-stars" role="img" aria-label="{{ rating_rounded }} sur 5" style="display:inline-flex; align-items:center; gap:1px; line-height:1;">
        {%- for i in (1..5) -%}
          {%- if i <= full -%}{%- assign c = star_color -%}{%- else -%}{%- assign c = '#d1d5db' -%}{%- endif -%}
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" style="color:{{ c }}; display:block;"><path fill="currentColor" d="m12 2 3 6.3 6.9.9-5 4.8 1.2 6.8L12 18l-6.1 3.6 1.2-6.8-5-4.8 6.9-.9L12 2Z"/></svg>
        {%- endfor -%}
      </span>
      <span class="modify-rating-num" style="font-weight:700; font-size:.95rem;">{{ rating_rounded }}</span>
      <span class="modify-review-count" style="font-size:.85rem; opacity:.7;">· {{ count }} avis client{% if count > 1 %}s{% endif %}</span>
    </div>
  {%- else -%}
    <div class="modify-no-reviews" style="display:flex; align-items:flex-start; gap:.6rem; padding:.75rem .9rem; border:1px solid #e5e7eb; border-radius:10px; background:#fafafa; font-size:.85rem; line-height:1.45; color:#52525b;">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" style="color:{{ star_color }}; flex-shrink:0; margin-top:1px;"><path fill="currentColor" d="m12 2 3 6.3 6.9.9-5 4.8 1.2 6.8L12 18l-6.1 3.6 1.2-6.8-5-4.8 6.9-.9L12 2Z"/></svg>
      <span>{{ block.settings.empty_message }}</span>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Modify Avis clients",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "paragraph", "content": "Affiche la vraie note et le vrai nombre d'avis de ce produit (via votre app d'avis). Aucune donnée n'est inventée : sans avis, un message vous invite à en collecter." },
    { "type": "color", "id": "star_color", "label": "Couleur des étoiles", "default": "#f59e0b" },
    { "type": "text", "id": "empty_message", "label": "Message sans avis", "default": "Vous n'avez pas encore d'avis. Modify va vous aider à en collecter." }
  ]
}
{% endschema %}
